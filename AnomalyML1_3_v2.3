# MEMORY-OPT: Helper to log memory usage so we can see which step spikes.
# On 16GB RAM, anything above ~10GB RSS is danger zone.
def _mem(tag=""):
    try:
        rss_gb = psutil.Process(os.getpid()).memory_info().rss / 1e9
        print(f"[MEM] {tag}: RSS={rss_gb:.2f} GB")
    except Exception:
        pass


# MEMORY-OPT: Downcast numeric columns in-place to cut memory ~50% on numeric data.
# SAFE MODE: Only downcasts int64 -> smaller int; LEAVES FLOATS AS float64 to preserve
# full precision in amount comparisons like (Pay_Amount == Invoice_Amount) and
# the 1%/2% tolerance checks in rulebased8/rulebased10. If you want more RAM savings
# at the cost of ~1e-7 relative precision on floats, uncomment the float block.
def _downcast_numeric(df):
    # for c in df.select_dtypes(include=['float64']).columns:
    #     df[c] = pd.to_numeric(df[c], downcast='float')  # disabled for safety
    for c in df.select_dtypes(include=['int64']).columns:
        df[c] = pd.to_numeric(df[c], downcast='integer')
    return df


