        # huge groups already produced Flag=0 (just via crash instead of skip). This
        # guard makes that behavior explicit and fast. We log how often it triggers.
        MAX_ITEMS_FOR_COMBINATIONS = 15
        _r10_skip_counter = {'skipped': 0, 'processed': 0}  # for post-run reporting

        def find_combinations(s_i, t_s):
            # MEMORY-OPT: guard against combinatorial explosion
            if len(s_i) > MAX_ITEMS_FOR_COMBINATIONS:
                return []
            result = []
            for r in range(1, len(s_i) +1):
                for comb in combinations(s_i, r):
                    if sum(comb) == t_s:
                        result.append(comb)
            return result


        def check_group(group):
            # MEMORY-OPT: The original returned the full group with Flag=0 for
            # non-matching cases. Since downstream filters to Flag==1, returning
            # empty DataFrames for non-matches is logically equivalent but lets
            # pandas concat 386k groups for ~free. This was the OOM cause:
            # post-groupby concat was materializing all 580k rows x 66 cols x
            # intermediate overhead, spiking past 16GB.
            EMPTY = group.iloc[0:0].assign(Flag=np.int8(0))  # zero-row, correct schema

            group = group[group['Pay_Amount'] != group['Invoice_Amount']]
            if len(group) == 0:
                return EMPTY
            # MEMORY-OPT: early skip of pathological groups — they produce no real
            # duplicate signal and their combinations explosion is what was killing RAM.
            if group['Suppliers_Invoice_Number'].nunique() > MAX_ITEMS_FOR_COMBINATIONS:
                _r10_skip_counter['skipped'] += 1
                return EMPTY  # was: return group with Flag=0 — same net effect
            _r10_skip_counter['processed'] += 1
            seen1 = set()
            for a in group['Suppliers_Invoice_Number'].unique():
                grouped_local = group[group['Suppliers_Invoice_Number']==a]
                if tuple(grouped_local['Pay_Amount'].sort_values().tolist()) not in seen1:
                    seen1.add(tuple(grouped_local['Pay_Amount'].sort_values().tolist()))
                else:
                    group = group[group['Suppliers_Invoice_Number']!=a]
            if len(group) == 0:
                return EMPTY
            i_a = group['Invoice_Amount'].iloc[0]
            s_i = group.groupby('Suppliers_Invoice_Number')['Pay_Amount'].sum().reset_index()
            try:
                combinations_result = find_combinations(s_i['Pay_Amount'].tolist(), i_a)
            except Exception:
                combinations_result = []
            if len(combinations_result) < 2:
                return EMPTY  # was: group with Flag=0
            valid_rows = set()
            for comb in combinations_result:
                for invoice in comb:
                    valid_rows.update(s_i[s_i['Pay_Amount']==invoice].index)
            valid_rows = list(valid_rows)
            group_filtered = group[group['Suppliers_Invoice_Number'].isin(s_i.loc[valid_rows, 'Suppliers_Invoice_Number'])]
            if len(group_filtered) == 0:
                return EMPTY
            t_p = group_filtered['Pay_Amount'].sum()
            t_i = 2 * group_filtered.iloc[0]['Invoice_Amount']
