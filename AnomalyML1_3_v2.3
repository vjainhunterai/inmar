    def getDataFromDatabase():
        # MEMORY-OPT: Original code did SELECT * FROM anomaly.duplicate_ap_invoice
        # just to get (a) the max Matched_Record_Number and (b) the column list.
        # On a large historical table this could easily be GBs. We now do two
        # tiny queries instead and return just what we need.
        a = readEncryptedConfig(CONFIG_PATH, env_local)
        user = a['user']
        pwd = a['password']
        password = urllib.parse.quote_plus(pwd)
        ip = a['host']
        schema = "anomaly"
        engine = create_engine('mysql+mysqlconnector://{0}:{1}@{2}/{3}'.format(user, password, ip, schema))
        # (1) column names only — LIMIT 0 returns no rows but full schema
        cols_query = "SELECT * FROM anomaly.duplicate_ap_invoice LIMIT 0"
        # (2) max Matched_Record_Number — scalar, cheap
        max_query = "SELECT MAX(Matched_Record_Number) AS max_mrn FROM anomaly.duplicate_ap_invoice"
        with engine.connect() as conn:
            cols_df = pd.read_sql(cols_query, conn)
            max_df = pd.read_sql(max_query, conn)
        # Build a lightweight frame that mimics what the original returned: empty
        # rows but correct columns, PLUS one row carrying the max value so the
        # downstream code path (len(combined1)>0 and combined1['Matched_Record_Number'].max())
        # still works without loading the whole table.
        result = cols_df.copy()
        max_val = max_df.iloc[0, 0] if len(max_df) else 0
        if pd.notna(max_val):
            # seed one sentinel row with just the max; other cols stay NaN/None
            seed = {c: None for c in result.columns}
            if 'Matched_Record_Number' in seed:
                seed['Matched_Record_Number'] = max_val
            result = pd.concat([result, pd.DataFrame([seed])], ignore_index=True)
        return result
