SELECT 
    SHA2(
        CONCAT_WS('|',
            COALESCE(`Supplier Invoice Document`, ''),
            COALESCE(`Company`, ''),
            COALESCE(`Invoice Status`, ''),
            COALESCE(`Supplier`, ''),
            COALESCE(`Supplier ID`, ''),
            COALESCE(CAST(`Invoice Date` AS CHAR), ''),
            COALESCE(CAST(`Invoice Created Date` AS CHAR), ''),
            COALESCE(`Purchase Orders`, ''),
            COALESCE(`Purchase Order Line`, ''),
            COALESCE(`Item`, ''),
            COALESCE(`Unit of Measure`, ''),
            COALESCE(CAST(`Distribution Quantity` AS CHAR), ''),
            COALESCE(`Line Description`, ''),
            COALESCE(CAST(`Unit Cost` AS CHAR), ''),
            COALESCE(`Ledger Account`, ''),
