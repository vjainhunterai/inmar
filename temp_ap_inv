            COALESCE(`Cost Center`, ''),
            COALESCE(`Cost Center ID`, ''),
            COALESCE(`Payment Status`, ''),
            COALESCE(CAST(`Payment Date` AS CHAR), ''),
            COALESCE(`FY25?`, ''),
            COALESCE(CAST(`Check Number` AS CHAR), ''),
            COALESCE(CAST(`Freight Amount` AS CHAR), ''),
            COALESCE(CAST(`Other Charges` AS CHAR), ''),
            COALESCE(`Supplier Invoice Line Distribution`, ''),
            COALESCE(CAST(`Invoice Line Amount` AS CHAR), ''),
            COALESCE(CAST(`Invoice Total Amount` AS CHAR), ''),
            COALESCE(CAST(`Derived Invoice Line Amount` AS CHAR), '')
        ), 256
    ) AS `hash_key`,
    seq_no,
    `Supplier Invoice Document`,                          -- SUPPLIER_INVOICE
     `Supplier Invoice Document`,                                                  -- INVOICE_NUMBER (not in source)
    `Company`,                                             -- COMPANY
    `Invoice Status`,                                      -- INVOICE_STATUS
    NULL,                                                  -- INTERCOMPANY
    NULL,                                                  -- DIRECT_INTERCOMPANY
    `Supplier`,                                            -- SUPPLIER
    `Supplier ID`,                                         -- SUPPLIER_ID
    NULL,                                                  -- DEFAULT_PAYMENT_TERMS
    NULL,                                                  -- DEFAULT_PAYMENT_TYPE
     `Supplier Invoice Document`,                                                  -- SUPPLIERS_INVOICE_NUMBER
    CASE
        WHEN LENGTH(SUBSTRING_INDEX(`Invoice Created Date`, '/', -1)) = 4
            THEN STR_TO_DATE(`Invoice Created Date`, '%m/%d/%Y')
        ELSE STR_TO_DATE(`Invoice Created Date`, '%m/%d/%y')
    END,                                                   -- CREATED_ON
    CASE
        WHEN LENGTH(SUBSTRING_INDEX(`Invoice Date`, '/', -1)) = 4
            THEN STR_TO_DATE(`Invoice Date`, '%m/%d/%Y')
        ELSE STR_TO_DATE(`Invoice Date`, '%m/%d/%y')
    END,                                                   -- INVOICE_DATE
    NULL,                                                  -- INVOICE_RECEIVED_DATE
    NULL,                                                  -- INVOICE_ACCOUNTING_DATE
    NULL,                                                  -- MEMO
    NULL,                                                  -- DISCOUNT_DATE
    NULL,                                                  -- DUE_DATE
    `Invoice Total Amount`,                                -- INVOICE_AMOUNT (derived total)
    NULL,                                                  -- INVOICE_STATUS1
    NULL,                                                  -- BALANCE_DUE
    NULL,                                                  -- CURRENCY
    NULL,                                                  -- IS_ON_HOLD_BLANK_IF_NO_AND_YES_IF_YES
    NULL,                                                  -- ADJUSTMENT
    NULL,                                                  -- ADJUSTMENT_REASON
    NULL,                                                  -- PROCUREMENT_RELATED
    `Purchase Orders`,                                     -- PURCHASE_ORDERS
    `Purchase Orders`,                                                  -- EXTERNAL_PO_NUMBER
    NULL,                                                  -- INVOICE_CREATED_BY
    `Derived Invoice Line Amount`,                                                  -- PAYMENT_AMOUNT
    NULL,                                                  -- PAYMENT_HANDLING_INSTRUCTION
    NULL,                                                  -- SUPPLIER_INVOICE_REFERENCE_ID
    `Check Number`,                                        -- CHECK_NUMBER
    `Cost Center`,                                         -- COST_CENTER
    Company,                                                  -- LOCATION
    NULL,                                                  -- SITE
    `Line Description`,                                    -- LINE_DESCRIPTION
    NULL,                                                  -- APPROVAL_DATE
    NULL,                                                  -- PAYMENT_TYPE
    NULL,                                                  -- SETTLEMENT_RUN_NUMBER
    NULL,                                                  -- IS_ON_HOLD
    NULL,                                                  -- SUPPLIER_DOCUMENT_RECEIVED
    `Distribution Quantity`,                               -- QUANTITY
    `Unit of Measure`,                                     -- UNIT_OF_MEASURE
    `Unit Cost`,                                           -- UNIT_COST
    `Invoice Line Amount`,                         -- EXTENDED_AMOUNT (derived line amount)
    NULL,                                                  -- DOCUMENT_LINK
    `Payment Date`,                                        -- PAYMENT_DATE
    NULL,                                                  -- DOCUMENT_PAYMENT_STATUS
    `Payment Status`,                                      -- PAYMENT_STATUS
    NULL,                                                  -- PROJECT
    NULL,                                                  -- GRANT
    NULL,                                                  -- GIFT
    NULL,                                                  -- LINE_COMPANY
    NULL,                                                  -- PAYEE_ALTERNATE_NAMES
    NULL,                                                  -- EXTERNAL_SYSTEM_ID_REFERENCE
    'admin',                                               -- load_user
