#!/usr/bin/env python3
"""
Excel to MySQL Loader — Notebook Version
==========================================
Run each section in a Jupyter/Colab cell.
"""

# %% [markdown]
# # Excel to MySQL Loader
# Load data from an Excel file into a MySQL database.

# %% Cell 1 — Install Dependencies (run once)
# !pip install pandas openpyxl sqlalchemy pymysql

# %% Cell 2 — Configuration
# ========== EDIT THESE VALUES ==========

EXCEL_FILE = "data.xlsx"        # Path to your Excel/CSV file
SHEET_NAME = None               # Sheet name or index (None = first sheet)

MYSQL_HOST = "localhost"
MYSQL_PORT = 3306
MYSQL_USER = "root"
MYSQL_PASSWORD = "your_password"
MYSQL_DATABASE = "your_database"

TABLE_NAME = None               # None = auto-derive from filename
IF_EXISTS = "replace"           # "replace" | "append" | "fail"
CHUNK_SIZE = 1000               # Rows per INSERT batch

# =======================================

# %% Cell 3 — Imports & Helper Functions

import re
import pandas as pd
from pathlib import Path
from sqlalchemy import create_engine, text
from urllib.parse import quote_plus


def sanitize_column_name(col: str) -> str:
    """Convert Excel header into a safe MySQL column name."""
    col = str(col).strip().lower()
    col = re.sub(r"[^a-z0-9_]", "_", col)
    col = re.sub(r"_+", "_", col).strip("_")
    if not col:
        col = "unnamed_col"
    if col[0].isdigit():
        col = f"col_{col}"
    return col


def deduplicate_columns(columns: list) -> list:
    """Append _1, _2, … to duplicate column names."""
    seen = {}
    result = []
    for c in columns:
        if c in seen:
            seen[c] += 1
            result.append(f"{c}_{seen[c]}")
        else:
            seen[c] = 0
            result.append(c)
    return result


# %% Cell 4 — Read Excel File

path = Path(EXCEL_FILE)
ext = path.suffix.lower()

if ext in (".csv", ".tsv"):
    df = pd.read_csv(EXCEL_FILE, sep="\t" if ext == ".tsv" else ",")
else:
    engine_name = "openpyxl" if ext in (".xlsx", ".xlsm") else "xlrd"
    kwargs = {"engine": engine_name}
    if SHEET_NAME is not None:
        kwargs["sheet_name"] = SHEET_NAME
    df = pd.read_excel(EXCEL_FILE, **kwargs)

# Sanitize column names
df.columns = deduplicate_columns([sanitize_column_name(c) for c in df.columns])

print(f"✓ Loaded {len(df)} rows × {len(df.columns)} columns")
print(f"  Columns: {list(df.columns)}")
df.head()

# %% Cell 5 — Clean Data

# Replace NaN/NaT with None (becomes MySQL NULL)
df = df.where(df.notna(), None)

# Strip whitespace from string columns
for col in df.columns:
    if df[col].dtype == "object":
        df[col] = df[col].map(lambda x: x.strip() if isinstance(x, str) else x)

# Auto-convert text columns that are actually numeric
for col in df.columns:
    if df[col].dtype == "object":
        try:
            converted = pd.to_numeric(df[col], errors="coerce")
            non_null = df[col].notna().sum()
            if non_null > 0 and converted.notna().sum() / non_null >= 0.8:
                df[col] = converted
        except Exception:
            pass

print("✓ Data cleaned")
print(f"\nData types:\n{df.dtypes}")
df.head()

# %% Cell 6 — Connect to MySQL

encoded_pw = quote_plus(MYSQL_PASSWORD)
connection_url = (
    f"mysql+pymysql://{MYSQL_USER}:{encoded_pw}@{MYSQL_HOST}:{MYSQL_PORT}"
    f"/{MYSQL_DATABASE}?charset=utf8mb4"
)
engine = create_engine(connection_url, pool_pre_ping=True)

# Test connection
with engine.connect() as conn:
    conn.execute(text("SELECT 1"))

print(f"✓ Connected to MySQL — {MYSQL_USER}@{MYSQL_HOST}:{MYSQL_PORT}/{MYSQL_DATABASE}")

# %% Cell 7 — Load Data into MySQL

table = TABLE_NAME or sanitize_column_name(path.stem)

df.to_sql(
    name=table,
    con=engine,
    if_exists=IF_EXISTS,
    index=False,
    chunksize=CHUNK_SIZE,
    method="multi",
)

# Verify
with engine.connect() as conn:
    count = conn.execute(text(f"SELECT COUNT(*) FROM `{table}`")).scalar()

print(f"✓ Done — {count} rows loaded into `{MYSQL_DATABASE}`.`{table}`")

# %% Cell 8 — Quick Verification (optional)

verify_df = pd.read_sql(f"SELECT * FROM `{table}` LIMIT 10", con=engine)
print(f"Preview of `{table}`:")
verify_df
